# .env - Configuration for the proxy server

# Server settings
HOST=0.0.0.0
PORT=8888

# --- Qwen 3.5 Configuration (recommended) ---
MODEL_NAME=mlx-community/Qwen3.5-4B-MLX-4bit
# Other Qwen 3.5 options (pick one):
#   mlx-community/Qwen3.5-0.8B-MLX-4bit   (tiny, fast, less capable)
#   mlx-community/Qwen3.5-2B-MLX-4bit     (small, good for testing)
#   mlx-community/Qwen3.5-4B-MLX-4bit     (balanced speed/quality)
#   mlx-community/Qwen3.5-9B-MLX-4bit     (higher quality, more VRAM)

# API-exposed model name (Claude Code expects a Claude model name)
API_MODEL_NAME=claude-4-sonnet-20250514

# Qwen models may need trust_remote_code for their tokenizer
# TRUST_REMOTE_CODE=true

# Some models need an explicit EOS token (uncomment if needed)
# EOS_TOKEN=

# Optional: manually set max context length (useful if model detection fails)
# MAX_CONTEXT_LENGTH=32768
